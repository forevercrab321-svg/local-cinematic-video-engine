{
  "name": "heartbreak_drift",
  "description": "Slow recession. Isolation grows. World moves away from subject.",
  "duration_sec": 5.0,
  "fps": 24,
  "aspect_ratio": "9:16",

  "camera": {
    "move": "pull_out",
    "zoom_start": 1.00,
    "zoom_end": 0.91,
    "x_start": 0.50,
    "x_end": 0.50,
    "y_start": 0.50,
    "y_end": 0.50,
    "rotation_start_deg": 0.0,
    "rotation_end_deg": -0.15,
    "easing": "ease_in"
  },

  "motion": {
    "micro_shake": 0.0,
    "breathing": 0.012,
    "parallax_strength": 0.12
  },

  "lighting": {
    "flicker": 0.0,
    "vignette_pulse": 0.04,
    "glow_drift": 0.0
  },

  "timing": {
    "hold_start_sec": 0.4,
    "main_move_start_sec": 0.4,
    "main_move_end_sec": 4.6,
    "hold_end_sec": 0.4
  },

  "output": {
    "codec": "h264",
    "pix_fmt": "yuv420p"
  }
}
