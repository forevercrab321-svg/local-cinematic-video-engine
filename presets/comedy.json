{
  "name": "comedy",
  "description": "Deadpan beat — static hold, timing pause, reaction cut",
  "mood_keywords": ["funny", "awkward", "deadpan", "punchline", "meme"],

  "camera_moves": [
    {
      "type": "static",
      "duration_frames": 72,
      "intensity": 0.0,
      "hold_frames": 48,
      "description": "Deadpan static hold — let the beat land"
    },
    {
      "type": "shake",
      "duration_frames": 8,
      "intensity": 0.8,
      "description": "Micro-shake on punchline — laugh trigger"
    },
    {
      "type": "pan_right",
      "duration_frames": 24,
      "intensity": 0.4,
      "description": "Quick pan to reaction — classic comedy cut"
    }
  ],

  "effects": [
    {
      "type": "breathing",
      "intensity": 0.2,
      "speed": 1.5,
      "description": "Light breath visible — humanizes the beat"
    },
    {
      "type": "film_grain",
      "intensity": 0.15,
      "description": "Slight grain — keeps it real, not cinematic"
    }
  ],

  "parallax": {
    "enabled": false,
    "layers": 1,
    "description": "Comedy = flat, not cinematic. No parallax."
  },

  "color_grade": {
    "saturation": 1.1,
    "contrast": 1.0,
    "temperature": 1000,
    "shadows": 5,
    "highlights": 5,
    "lift": 0.0,
    "gamma": 1.0,
    "warm_and_bright": true
  },

  "subtitle_style": {
    "enabled": true,
    "position": "bottom",
    "style": "meme",
    "font": "Impact",
    "description": "Meme-style captions for punchline text"
  },

  "audio_suggestion": "Comedy bass hit, rim shot, record scratch",
  "cut_recommendation": "Hold deadpan 1-3 seconds, punchline = quick cut or smash",
  "use_cases": [
    "Character's dumb response to situation",
    "Unexpected face reaction",
    "Text on screen reveal",
    "POV: you're doing something embarrassing"
  ]
}
